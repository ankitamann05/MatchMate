<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MatchMate" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.MatchMate" parent="Base.Theme.MatchMate" />

    <style name="Theme.MatchMate.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/matchmate_brand</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_matchmate_splash</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/matchmate_splash_icon_background</item>
        <item name="postSplashScreenTheme">@style/Theme.MatchMate</item>
    </style>

    <style name="ShapeAppearanceMatchMateProfilePhoto">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">18dp</item>
        <item name="cornerSizeTopRight">18dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
